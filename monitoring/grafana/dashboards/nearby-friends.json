      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/api/locations/.*\", method=\"POST\", job=\"location-service\"}[1m]))",
          "legendFormat": "Published (total)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_server_requests_seconds_count{uri=~\"/api/locations/.*\", method=\"POST\", job=\"location-service\"}[1m])",
